{
  "destination": "./backups",
  "storage_type": "local",
  "auto_backup": false,
  "interval_min": 30,
  "retention_days": 30,
  "webhook_url": "",
  "watches": [],
  "default_exclude_patterns": [
    ".git",
    ".gitignore",
    "__pycache__",
    "node_modules",
    "*.pyc",
    "*.tmp",
    ".DS_Store",
    "Thumbs.db",
    "*.lock",
    "*.db",
    "*.sqlite*",
    ".env"
  ],
  "compression_enabled": false,
  "auto_retry": false,
  "retry_delay_min": 5,
  "max_backup_mbps": 0,
  "email_config": {
    "enabled": false,
    "smtp_host": "",
    "smtp_port": 587,
    "username": "",
    "password": "",
    "from_addr": "",
    "to_addr": ""
  }
}